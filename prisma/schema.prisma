generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ItemStatus {
  AVAILABLE
  CLAIMED
  PURCHASED
}

model User {
  id            String        @id @default(cuid())
  username      String        @unique
  password      String
  name          String
  avatarUrl     String?
  telegramId    String?       @unique
  telegramUsername String?
  telegramLinkedAt DateTime?
  telegramConfirmedAt DateTime?
  telegramNotificationsEnabled Boolean @default(false)
  role          Role          @default(USER)
  items         Item[]
  claimedItems  Item[]         @relation("ItemClaimedByUser")
  lists         List[]
  listViewers   ListViewer[]
  itemComments  ItemComment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([username])
  @@index([role])
  @@index([telegramConfirmedAt])
}

model List {
  id        String       @id @default(cuid())
  name      String
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Item[]
  viewers   ListViewer[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId])
}

model ListViewer {
  listId   String
  list     List     @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([listId, userId])
  @@index([userId])
}

model Item {
  id          String        @id @default(cuid())
  title       String
  url         String?
  price       Float?
  currency    String        @default("RUB")
  priority    Int           @default(3) // 1-5
  images      String[] // Array of image URLs
  notes       String?
  purchased   Boolean       @default(false)
  purchasedAt DateTime?
  status      ItemStatus    @default(AVAILABLE)
  claimedByUserId String?
  claimedByUser   User?     @relation("ItemClaimedByUser", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimedAt   DateTime?
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  listId      String?
  list        List?         @relation(fields: [listId], references: [id], onDelete: SetNull)
  tags        Tag[]
  comments    ItemComment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId])
  @@index([listId])
  @@index([purchased])
  @@index([createdAt])
  @@index([userId, purchased])
  @@index([userId, createdAt])
  @@index([status])
  @@index([claimedByUserId])
}

model ItemComment {
  id        String   @id @default(cuid())
  text      String   @db.VarChar(2000)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([userId])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6366f1")
  items Item[]

  @@index([name])
}
