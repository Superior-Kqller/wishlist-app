# Database
DB_PASSWORD=your-strong-password-here
DATABASE_URL=postgresql://wishlist:your-strong-password-here@db:5432/wishlist

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://wishlist.yourdomain.com
# Для локальной разработки: http://localhost:4030
# Для работы за reverse proxy (опционально):
# AUTH_TRUST_HOST=true

# Telegram bot (опционально)
# Токен бота от BotFather, формат: 123456789:AA...
TELEGRAM_BOT_TOKEN=
# Секрет для валидации webhook заголовка x-telegram-bot-api-secret-token
TELEGRAM_WEBHOOK_SECRET=

# Valkey (опционально, fallback на in-memory)
# Unix-сокет (docker-compose):
REDIS_URL=/run/valkey/valkey.sock
# TCP (если без сокета): REDIS_URL=redis://wishlist-valkey:6379

# App
APP_PORT=4030

# Не задавайте NODE_ENV в .env для обычной разработки/сборки: скрипт `npm run build`
# сам выставляет production. Неверное значение ломает пререндер и React.

# Seed users (used only during first setup)
SEED_USER1_USERNAME=user1
# Production: обязательно замените на сильный пароль (не пустой и не "changeme")
SEED_USER1_PASSWORD=changeme
SEED_USER1_NAME=User One
SEED_USER2_USERNAME=user2
# Production: обязательно замените на сильный пароль (не пустой и не "changeme")
SEED_USER2_PASSWORD=changeme
SEED_USER2_NAME=User Two
