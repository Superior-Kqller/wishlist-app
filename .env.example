# Database
DB_PASSWORD=your-strong-password-here
DATABASE_URL=postgresql://wishlist:your-strong-password-here@db:5432/wishlist

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://wishlist.yourdomain.com
# Для локальной разработки: http://localhost:4030
# Для работы за reverse proxy (опционально):
# AUTH_TRUST_HOST=true

# Redis (опционально, fallback на in-memory)
# Unix-сокет (docker-compose):
REDIS_URL=/run/redis/redis.sock
# TCP (если без сокета): REDIS_URL=redis://wishlist-redis:6379

# App
APP_PORT=4030

# Seed users (used only during first setup)
SEED_USER1_USERNAME=user1
SEED_USER1_PASSWORD=changeme
SEED_USER1_NAME=User One
SEED_USER2_USERNAME=user2
SEED_USER2_PASSWORD=changeme
SEED_USER2_NAME=User Two
